#!/usr/bin/env sh
# Opt-in, billable Claude Code setup-token verification (issues #49/#57).
#
# Requires CLAUDE_CODE_OAUTH_TOKEN in the repository .env or exported environment.
# Enable with: HARNESS_LIVE_CLAUDE_SMOKE=1 bin/verify-claude-oauth
# Exit: 0 verified; 1 failed; 77 skipped (not opted in).
set -eu

if [ "${HARNESS_LIVE_CLAUDE_SMOKE:-}" != "1" ]; then
  printf '%s\n' 'SKIP: set HARNESS_LIVE_CLAUDE_SMOKE=1 to run the billable Claude verification.' >&2
  exit 77
fi

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
# bin/container forwards the repository .env using Docker --env-file. Explicitly
# pass only non-secret control variables; the OAuth value is never printed here.
exec "$repo_root/bin/container" \
  --writable-workspace \
  --stdin-only \
  --env HARNESS_LIVE_CLAUDE_SMOKE \
  --env HARNESS_CLAUDE_EVIDENCE_DIR \
  --env HARNESS_LOG_DIR \
  --load scripts/verify-claude-oauth.lisp
