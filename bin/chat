#!/usr/bin/env sh
# Run a chat/tool-call session inside the project Docker runtime.
set -eu

usage() {
  cat <<'USAGE'
Usage: bin/chat [-c|--continue] [--backend BACKEND] [--codex-home PATH]
                [--model MODEL] [--max-rounds N] [--session-id ID]
                [--prompt TEXT] [--supervised] [--fake]

With --prompt, run one prompt through the selected backend and the harness tool
loop until it returns a final response. Without --prompt, a terminal stdin/stdout
starts an interactive multi-turn session; type /exit or /quit, press Ctrl-C, or
send EOF to leave.
Interactive slash commands: /reload reloads harness sources in-process; /max-rounds [N] shows or sets the live tool-loop limit.
Piped stdin remains a one-shot prompt and is never interpreted as a transcript.

-c, --continue resumes the most recent session by default. Combine it with
--session-id ID to resume that specific durable `agent-logs/ID.history.json`
session; the snapshot is reloaded as the starting conversation
(including tool calls and results), and the resumed turns append to that
session's log files. The snapshot's model and max-rounds are adopted unless you
also pass --model/--max-rounds. Errors (no snapshot) fall back to a fresh session.

--backend selects the provider adapter (CLI; preferred over env):
  openrouter  (default) OpenRouter Chat Completions via OPENROUTER_API_KEY
  synthetic             Synthetic OpenAI-compatible Chat Completions via SYNTHETIC_API_KEY
  codex       ChatGPT/Codex *subscription* via local codex app-server (no API key)
  claude      Claude Code CLI via CLAUDE_CODE_OAUTH_TOKEN setup-token (no API key)

HARNESS_BACKEND=openai is rejected. --backend openai errors at the CLI.

--codex-home PATH sets CODEX_HOME for the Codex subscription backend (OAuth home
with auth.json). Relative paths are resolved under the repo and mapped to the
container workspace (/workspace/...). Required in practice for --backend codex
after a human `codex login`. Ignored for openrouter.

At startup the chat process loads the workspace env file (default
/workspace/.env, i.e. the repo-root .env under the bind mount; override with
HARNESS_ENV_FILE) and sets each KEY=value into its own environment so tools
run through run_shell (e.g. git/gh needing GITHUB_TOKEN) inherit them.
Variables already set in the process environment are not overridden. The
loader logs the file path and the names it set on stderr, never the values.

--supervised explicitly forces machine-stream interactive mode for a supervisor.
It is the only mode that accepts a non-terminal transcript as persistent turns;
normal terminal and piped one-shot behavior is unchanged. --fake selects the
deterministic no-provider backend for offline integration tests only.

Defaults:
  --backend     openrouter
  --model       openai/gpt-4.1-mini (exact OpenRouter model ID; for codex use a
                Codex/subscription model id such as gpt-5-codex; for Synthetic,
                prefer an exact model ID over a rotating syn: alias)
  --max-rounds  60
  --session-id  an ISO-8601 UTC timestamp session id (generated when omitted)

Pass --session-id when a supervisor owns correlation. Prefer an ISO-8601 UTC
timestamp so the durable log path is agent-logs/$ISO-TIMESTAMP.jsonl in the
workspace checkout. Non-timestamp values still work for stderr correlation, but
the log file basename is always an ISO timestamp. Without --session-id, bin/chat
generates a fresh UTC timestamp; it is not a credential and not a resume token.

For --backend openrouter or synthetic, pass the Models API's `id` field to
--model, not a display name. Synthetic `syn:` aliases intentionally rotate;
pin a returned exact model ID for reproducible runs. This chat supplies
run_shell and reload_harness, so choose a model supporting the `tools` parameter.

One-shot failures are non-zero. Interactive failed turns are reported on stderr
and the session continues with its previous history; a later normal exit is
non-zero if any turn failed. All Lisp execution stays in Docker.

Examples:
  bin/chat --model openai/gpt-4.1-mini --prompt 'hello'
  bin/chat --backend codex --codex-home .codex-home --model gpt-5-codex
USAGE
}

backend=openrouter
backend_supplied=false
codex_home=
codex_home_supplied=false
model=openai/gpt-4.1-mini
max_rounds=60
session_id=
session_id_supplied=false
prompt=
prompt_supplied=false
supervised=false
fake_backend=false
continue_session=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help|-h) usage; exit 0 ;;
    -c|--continue)
      continue_session=true; shift ;;
    --backend)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --backend requires a value' >&2; exit 2; }
      backend=$2; backend_supplied=true; shift 2 ;;
    --codex-home)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --codex-home requires a path' >&2; exit 2; }
      codex_home=$2; codex_home_supplied=true; shift 2 ;;
    --model)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --model requires a value' >&2; exit 2; }
      model=$2; shift 2 ;;
    --max-rounds)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --max-rounds requires a value' >&2; exit 2; }
      max_rounds=$2; shift 2 ;;
    --session-id)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --session-id requires a value' >&2; exit 2; }
      session_id=$2; session_id_supplied=true; shift 2 ;;
    --prompt)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/chat: --prompt requires text' >&2; exit 2; }
      prompt=$2; prompt_supplied=true; shift 2 ;;
    --supervised)
      supervised=true; shift ;;
    --fake)
      fake_backend=true; shift ;;
    *) printf 'bin/chat: unknown argument: %s\n' "$1" >&2; usage >&2; exit 2 ;;
  esac
done

case "$max_rounds" in
  ''|*[!0-9]*) printf '%s\n' 'bin/chat: --max-rounds must be a positive integer' >&2; exit 2 ;;
esac
[ "$max_rounds" -gt 0 ] || { printf '%s\n' 'bin/chat: --max-rounds must be positive' >&2; exit 2; }
[ -n "$model" ] || { printf '%s\n' 'bin/chat: --model must not be empty' >&2; exit 2; }
if [ "$session_id_supplied" = true ]; then
  [ -n "$session_id" ] || { printf '%s\n' 'bin/chat: session ID must not be empty' >&2; exit 2; }
elif [ "$continue_session" = true ]; then
  # Resume: the Lisp side reads the most recent agent-logs/*.history.json and
  # adopts its session id so logs continue. Leave session_id empty here.
  session_id=
else
  # Per-session files are $ISO-TIMESTAMP.jsonl (UTC, millisecond precision).
  session_id=$(date -u +%Y-%m-%dT%H:%M:%S.000Z 2>/dev/null) ||     session_id=$(python3 -c 'from datetime import datetime, timezone; print(datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%S.%f")[:-3]+"Z")')
fi

# Normalize backend name (case-insensitive).
backend_normalized=$(printf '%s' "$backend" | tr '[:upper:]' '[:lower:]')
case "$backend_normalized" in
  openrouter|synthetic|codex|claude) backend=$backend_normalized ;;
  openai)
    printf '%s\n' 'bin/chat: --backend openai is not supported (no OPENAI_API_KEY / OpenAI Platform billing). Use --backend codex for ChatGPT/Codex subscription usage, or openrouter.' >&2
    exit 2
    ;;
  *)
    printf '%s\n' "bin/chat: --backend must be openrouter, synthetic, codex, or claude, got: $backend" >&2
    exit 2
    ;;
esac

if [ "$codex_home_supplied" = true ]; then
  [ -n "$codex_home" ] || { printf '%s\n' 'bin/chat: --codex-home must not be empty' >&2; exit 2; }
fi
if [ "$backend" != codex ] && [ "$codex_home_supplied" = true ]; then
  printf '%s\n' 'bin/chat: --codex-home is only valid with --backend codex' >&2
  exit 2
fi

mode=one-shot
if [ "$prompt_supplied" = false ]; then
  if [ "$supervised" = true ]; then
    mode=interactive
  elif [ ! -t 0 ]; then
    prompt=$(cat)
  elif [ -t 1 ]; then
    mode=interactive
  else
    printf '%s\n' 'bin/chat: use --prompt or piped stdin when stdout is not a terminal' >&2
    exit 2
  fi
fi
[ "$mode" = interactive ] || [ -n "$prompt" ] || { printf '%s\n' 'bin/chat: prompt must not be empty' >&2; exit 2; }
if [ "$supervised" = true ] && [ "$prompt_supplied" = true ]; then
  printf '%s\n' 'bin/chat: --supervised cannot be combined with --prompt' >&2
  exit 2
fi

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
container_runner=${HARNESS_CHAT_RUNNER:-"$repo_root/bin/container"}
# Resolve the env-file the same way the Lisp side does (HARNESS_ENV_FILE wins,
# else the repo-root .env), so this guard and the loader never disagree.
env_file=${HARNESS_ENV_FILE:-"$repo_root/.env"}

# Credential guard depends on backend. Codex uses subscription OAuth in
# CODEX_HOME (no OPENROUTER_API_KEY). Fake backend skips provider credentials.
if [ "$fake_backend" = false ]; then
  if [ "$backend" = openrouter ]; then
    if [ -z "${OPENROUTER_API_KEY:-}" ] && [ ! -f "$env_file" ]; then
      printf '%s\n' 'bin/chat: OPENROUTER_API_KEY must be exported or set in .env' >&2
      exit 2
    fi
  elif [ "$backend" = synthetic ]; then
    if [ -z "${SYNTHETIC_API_KEY:-}" ] && [ ! -f "$env_file" ]; then
      printf '%s\n' 'bin/chat: SYNTHETIC_API_KEY must be exported or set in .env' >&2
      exit 2
    fi
  fi
fi

# Map a host --codex-home path to a container-visible CODEX_HOME under the
# /workspace bind mount when the path lives in the repo; leave already-container
# paths (/workspace/...) and foreign absolute paths unchanged.
container_codex_home=
if [ "$codex_home_supplied" = true ]; then
  case "$codex_home" in
    /workspace/*)
      container_codex_home=$codex_home
      ;;
    /*)
      case "$codex_home" in
        "$repo_root"|"$repo_root"/*)
          rel=${codex_home#"$repo_root"}
          rel=${rel#/}
          if [ -n "$rel" ]; then
            container_codex_home="/workspace/$rel"
          else
            container_codex_home="/workspace"
          fi
          ;;
        *)
          # Absolute path outside the repo: forward as-is (caller must ensure
          # visibility inside the container, e.g. via an existing mount).
          container_codex_home=$codex_home
          ;;
      esac
      ;;
    *)
      # Relative to repo root -> /workspace/<rel>
      rel=${codex_home#./}
      container_codex_home="/workspace/$rel"
      ;;
  esac
fi

# SBCL's default dynamic space is 1 GiB. A long chat retains every tool result in
# history and re-serializes the whole transcript each round, so the default heap
# can exhaust mid-session -- and because bin/chat cannot pass --non-interactive,
# exhaustion drops into the debugger and blocks on stdin (a silent hang). Give
# the process real headroom; override with HARNESS_CHAT_DYNAMIC_SPACE_MB.
dynamic_space_mb=${HARNESS_CHAT_DYNAMIC_SPACE_MB:-4096}
case "$dynamic_space_mb" in
  ''|*[!0-9]*) printf '%s\n' 'bin/chat: HARNESS_CHAT_DYNAMIC_SPACE_MB must be a positive integer (MiB)' >&2; exit 2 ;;
esac
[ "$dynamic_space_mb" -gt 0 ] || { printf '%s\n' 'bin/chat: HARNESS_CHAT_DYNAMIC_SPACE_MB must be positive' >&2; exit 2; }

export HARNESS_CHAT_MODE=$mode
export HARNESS_CHAT_MODEL=$model
if [ "$continue_session" = true ]; then
  export HARNESS_CHAT_RESUME=1
fi
export HARNESS_CHAT_MAX_ROUNDS=$max_rounds
export HARNESS_CHAT_SESSION_ID=$session_id
# CLI --backend wins over any ambient HARNESS_BACKEND by exporting it here.
export HARNESS_BACKEND=$backend
export HARNESS_CHAT_BACKEND_EXPLICIT=$backend_supplied
if [ -n "$container_codex_home" ]; then
  export CODEX_HOME=$container_codex_home
fi
if [ "$supervised" = true ]; then
  export HARNESS_CHAT_STREAM_MODE=supervised
fi
if [ "$fake_backend" = true ]; then
  export HARNESS_CHAT_FAKE_BACKEND=1
fi
if [ "$mode" = one-shot ]; then
  export HARNESS_CHAT_PROMPT=$prompt
fi

if [ "$mode" = interactive ]; then
  container_interaction=--interactive
  if [ "$supervised" = true ]; then
    container_interaction=--stdin-only
  fi
  exec "$container_runner" --writable-workspace "$container_interaction" \
    --env HARNESS_CHAT_MODE \
    --env HARNESS_ENV_FILE \
    --env HARNESS_CHAT_MODEL \
    --env HARNESS_CHAT_MAX_ROUNDS \
    --env HARNESS_CHAT_SESSION_ID \
    --env HARNESS_CHAT_RESUME \
    --env HARNESS_CHAT_STREAM_MODE \
    --env HARNESS_CHAT_FAKE_BACKEND \
    --env HARNESS_BACKEND \
    --env HARNESS_CHAT_BACKEND_EXPLICIT \
    --env CODEX_HOME \
    --dynamic-space-size "$dynamic_space_mb" \
    --noinform \
    --load scripts/chat.lisp
fi

exec "$container_runner" --writable-workspace \
  --env HARNESS_CHAT_MODE \
  --env HARNESS_ENV_FILE \
  --env HARNESS_CHAT_PROMPT \
  --env HARNESS_CHAT_MODEL \
  --env HARNESS_CHAT_MAX_ROUNDS \
  --env HARNESS_CHAT_SESSION_ID \
  --env HARNESS_CHAT_RESUME \
  --env HARNESS_CHAT_FAKE_BACKEND \
  --env HARNESS_BACKEND \
  --env HARNESS_CHAT_BACKEND_EXPLICIT \
  --env CODEX_HOME \
  --dynamic-space-size "$dynamic_space_mb" \
  --noinform \
  --load scripts/chat.lisp
