#!/usr/bin/env sh
# Run any Common Lisp command for this repository inside the project container.
set -eu

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
image=${HARNESS_IMAGE:-self-improving-agent-harness:dev}
network_option=
stdin_option=
forward_env_options=
workspace_mount="$repo_root:/workspace:ro"
publish_option=
publish_scope=loopback

# Only repository-provided wrappers may disable networking. This is intentionally
# a narrow switch instead of accepting arbitrary Docker options from the caller.
while [ "$#" -gt 0 ]; do
  case "$1" in
    --interactive)
      stdin_option=-it
      shift
      ;;
    --stdin-only)
      # Machine supervisors need stdin without a Docker TTY so stdout/stderr
      # remain separate ordinary streams.
      stdin_option=-i
      shift
      ;;
    --no-network)
      network_option=--network=none
      shift
      ;;
    --writable-workspace)
      workspace_mount="$repo_root:/workspace"
      shift
      ;;
    --publish-loopback|--publish-any)
      [ "$#" -ge 2 ] || { printf '%s\n' "$1 requires HOST_PORT:CONTAINER_PORT" >&2; exit 2; }
      [ -z "${publish_option:-}" ] || { printf '%s\n' 'bin/container: a publish option may be supplied only once' >&2; exit 2; }
      publish_scope=$1
      mapping=$2
      host_port=${mapping%%:*}
      container_port=${mapping#*:}
      case "$mapping" in
        *:* ) ;;
        * ) printf '%s\n' 'bin/container: port mapping must be HOST_PORT:CONTAINER_PORT' >&2; exit 2 ;;
      esac
      case "$host_port:$container_port" in
        *[!0-9:]*|:*|*:|*:*:* ) printf '%s\n' 'bin/container: ports must be decimal integers' >&2; exit 2 ;;
      esac
      [ "$host_port" -ge 1 ] && [ "$host_port" -le 65535 ] \
        && [ "$container_port" -ge 1 ] && [ "$container_port" -le 65535 ] \
        || { printf '%s\n' 'bin/container: ports must be in 1..65535' >&2; exit 2; }
      if [ "$publish_scope" = --publish-any ]; then
        publish_option="--publish 0.0.0.0:$host_port:$container_port"
      else
        publish_option="--publish 127.0.0.1:$host_port:$container_port"
      fi
      shift 2
      ;;
    --env)
      [ "$#" -ge 2 ] || { printf '%s\n' 'bin/container: --env requires a variable name' >&2; exit 2; }
      case "$2" in
        *[!A-Za-z0-9_]*|'')
          printf '%s\n' 'bin/container: invalid environment variable name' >&2
          exit 2
          ;;
      esac
      forward_env_options="$forward_env_options --env $2"
      shift 2
      ;;
    *) break ;;
  esac
done

# Building is explicit and repeatable; source is never copied into the image.
docker build --tag "$image" "$repo_root"

# Forward host-exported runtime config without printing values. Host exports
# override .env for the same names. OPENAI_API_KEY is intentionally NOT
# forwarded: OpenAI Platform API-key billing is out of scope; subscription
# usage goes through HARNESS_BACKEND=codex + Codex-managed OAuth (CODEX_HOME).
host_key_options=
if [ "${OPENROUTER_API_KEY+x}" = x ]; then
  host_key_options="$host_key_options --env OPENROUTER_API_KEY"
fi
if [ "${HARNESS_BACKEND+x}" = x ]; then
  host_key_options="$host_key_options --env HARNESS_BACKEND"
fi
if [ "${CODEX_HOME+x}" = x ]; then
  host_key_options="$host_key_options --env CODEX_HOME"
fi
if [ "${CLAUDE_CODE_OAUTH_TOKEN+x}" = x ]; then
  host_key_options="$host_key_options --env CLAUDE_CODE_OAUTH_TOKEN"
fi
if [ "${HARNESS_LIVE_CODEX_SMOKE+x}" = x ]; then
  host_key_options="$host_key_options --env HARNESS_LIVE_CODEX_SMOKE"
fi
if [ "${HARNESS_LIVE_CLAUDE_SMOKE+x}" = x ]; then
  host_key_options="$host_key_options --env HARNESS_LIVE_CLAUDE_SMOKE"
fi

# The --no-network switch is understood only by bin/container and becomes
# Docker's --network=none option before the image name.
if [ -f "$repo_root/.env" ]; then
  exec docker run ${network_option:-} ${stdin_option:-} ${forward_env_options:-} ${host_key_options:-} ${publish_option:-} --rm --init \
    --env-file "$repo_root/.env" \
    --volume "$workspace_mount" \
    --volume self-improving-agent-harness-cache:/cache \
    --volume self-improving-agent-harness-logs:/logs \
    --workdir /workspace "$image" "$@"
fi

exec docker run ${network_option:-} ${stdin_option:-} ${forward_env_options:-} ${host_key_options:-} ${publish_option:-} --rm --init \
  --volume "$workspace_mount" \
  --volume self-improving-agent-harness-cache:/cache \
  --volume self-improving-agent-harness-logs:/logs \
  --workdir /workspace "$image" "$@"
